body {
    background: linear-gradient(45deg, #121212, #301934); /* Fundo escuro elegante */
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    color: white;
}

.card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-align: center;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
}

h1 {
    color: #a29bfe; /* Roxo clarinho */
    margin-bottom: 20px;
}

.assinatura {
    margin-top: 30px;
    font-style: italic;
    font-size: 0.9rem;
    color: #ddd;
}