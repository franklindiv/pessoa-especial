/* Configurações Globais e Fontes */
* {
    margin: 0;
    padding: 0;
    box-shadow: none !important; /* Remove sombras antigas indesejadas */
    box-sizing: border-box;
}

body {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: 'Poppins', sans-serif;
    color: white;
    overflow: hidden; /* Evita barras de rolagem estranhas */
    
    /* Fundo: Gradiente sutil simulando a luz da sala de aula */
    background: radial-gradient(circle at center, #2c3e50 0%, #1a1a1a 100%);
    
    /* Efeito de desfoque no fundo para destacar o mural (Glassmorphism no body) */
    position: relative;
}

/* O Quadro Negro Principal (O "Chalkboard") */
.quadro-negro {
    width: 90%;
    max-width: 1000px;
    height: 85vh;
    background: rgba(0, 0, 0, 0.5); /* Fundo escuro semi-transparente */
    backdrop-filter: blur(15px); /* O "segredo" do efeito de vidro */
    border-radius: 30px;
    border: 2px solid rgba(255, 255, 255, 0.1);
    padding: 40px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.7);
    position: relative;
}

/* Títulos */
header {
    text-align: center;
    margin-bottom: 40px;
}

.titulo-nostalgia {
    font-family: 'Pacifico', cursive; /* Fonte manuscrita nostálgica */
    font-size: 3.5rem;
    color: #f1c40f; /* Amarelo giz */
    text-shadow: 2px 2px 5px rgba(241, 196, 15, 0.5);
    margin-bottom: 10px;
}

.subtitulo {
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #bdc3c7;
}

/* O Mural e os Post-its */
.mural {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 30px;
    padding: 20px;
    overflow-y: auto; /* Permite rolar se tiver muitas notas */
}

/* Base dos Post-its com efeito de vidro colorido */
.post-it {
    width: 280px;
    min-height: 180px;
    padding: 25px;
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(5px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-size: 1.1rem;
    line-height: 1.5;
    position: relative;
    
    /* Animação de flutuação suave */
    animation: flutuar 6s ease-in-out infinite;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* Efeito de Hover (passar o mouse) */
.post-it:hover {
    transform: scale(1.05) rotate(2deg); /* Gira e cresce levemente */
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.3);
    cursor: pointer;
}

/* Cores específicas dos Post-its (Vibe Giz/Cores Pastéis) */
.nota-amarela {
    background: rgba(241, 196, 15, 0.15); /* Amarelo sutil */
    border-color: rgba(241, 196, 15, 0.3);
}

.nota-azul {
    background: rgba(52, 152, 219, 0.15); /* Azul sutil */
    border-color: rgba(52, 152, 219, 0.3);
    animation-delay: 1s; /* Atraso para as animações não ficarem iguais */
}

.nota-rosa {
    background: rgba(231, 76, 60, 0.15); /* Rosa sutil */
    border-color: rgba(231, 76, 60, 0.3);
    animation-delay: 2s;
}

/* Texto do Autor */
.autor {
    font-weight: 600;
    text-align: right;
    margin-top: 15px;
    font-size: 0.9rem;
    color: #ecf0f1;
}

/* Rodapé */
footer {
    text-align: center;
    margin-top: 30px;
    font-size: 0.8rem;
    color: #7f8c8d;
}

/* Definição da Animação de Flutuação */
@keyframes flutuar {
    0%, 100% {
        transform: translateY(0) rotate(0deg);
    }
    50% {
        transform: translateY(-15px) rotate(-1deg);
    }
}